---
import ListLayout from "../../layouts/ListLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const tagMap = new Map<string, number>();

for (const post of posts) {
  for (const tag of post.data.tags) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

const sortedTags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]);
---

<ListLayout title="Tags">
  <h1>Tags</h1>
  <p class="subtitle">Tots els temes del blog</p>
  <div class="tags-grid">
    {sortedTags.map(([tag, count]) => (
      <a href={`/blog/tags/${tag.toLowerCase()}/`} class="tag-card">
        <span class="tag-name">{tag}</span>
        <span class="tag-count">{count} article{(count > 1) ? "s" : ""}</span>
      </a>
    ))}
  </div>
</ListLayout>

<style>
  .subtitle {
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  .tags-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }

  .tag-card {
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem;
    text-align: center;
    transition: box-shadow var(--transition), transform var(--transition),
      border-color var(--transition);
  }

  .tag-card:hover {
    box-shadow: 0 4px 20px rgba(109, 74, 255, 0.15);
    transform: translateY(-2px);
    border-color: var(--color-primary);
  }

  .tag-name {
    font-weight: 600;
    font-size: 1.1rem;
    display: block;
    margin-bottom: 0.25rem;
  }

  .tag-count {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }
</style>
