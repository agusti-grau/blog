---
import { AUTHOR, LINKEDIN_URL, GITHUB_URL } from "../consts";
---

<footer class="footer">
  <div class="footer-inner">
    <p class="footer-name">&copy; {new Date().getFullYear()} {AUTHOR}</p>
    <p class="footer-desc">
      Contingut tècnic en català sobre Microsoft Azure, Intune, SCCM i Windows
    </p>
    <div class="footer-links">
      <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer">
        LinkedIn
      </a>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer">
        GitHub
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    margin-top: 3rem;
    padding: 2rem 1.5rem;
    text-align: center;
    transition: border-color var(--transition);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer-name {
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .footer-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
    font-size: 0.9rem;
  }
</style>
